SECRET_KEY=your-secret-key-here

# True for local development. Set to False in production - this also
# switches on strict cookie/HSTS security settings below.
DEBUG=True

# Comma-separated. Required (non-empty) when DEBUG=False.
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=trade_cycle_engine
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=5432

# Optional. When set, takes priority over the DB_* variables above - this
# is how Render (and most PaaS providers) inject database credentials.
# Leave unset for local development.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Production-only (DEBUG=False). Defaults shown.
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
